    {
      "name": "Spaces",
      "item": [
        {
          "name": "Create space (ADMIN)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Ejecutiva\",\n  \"type\": \"MEETING_ROOM\",\n  \"capacity\": 10,\n  \"location\": \"Nivel 5\",\n  \"hourlyRate\": 120.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/spaces", "host": ["{{baseUrl}}"], "path": ["api", "spaces"] }
          }
        },
        {
          "name": "List spaces",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/spaces", "host": ["{{baseUrl}}"], "path": ["api", "spaces"] }
          }
        },
        {
          "name": "Get space by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/spaces/1", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "1"] }
          }
        },
        {
          "name": "List inactive spaces (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/spaces/inactive", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "inactive"] }
          }
        },
        {
          "name": "Update space (ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Sala Ejecutiva Renovada\",\n  \"type\": \"MEETING_ROOM\",\n  \"capacity\": 12,\n  \"location\": \"Nivel 5\",\n  \"hourlyRate\": 135.00\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/spaces/1", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "1"] }
          }
        },
        {
          "name": "Delete (deactivate) space (ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/spaces/1", "host": ["{{baseUrl}}"], "path": ["api", "spaces", "1"] }
          }
        }
      ]
    },
    {
