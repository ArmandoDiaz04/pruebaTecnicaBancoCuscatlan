        {
          "name": "Occupancy report (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/reports/occupancy?from=2026-07-01&to=2026-07-31",
