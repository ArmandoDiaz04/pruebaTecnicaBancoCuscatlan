            "body": {
              "mode": "raw",
              "raw": "{\n  \"spaceId\": 1,\n  \"startDateTime\": \"2026-07-10T10:00:00\",\n  \"endDateTime\": \"2026-07-10T12:00:00\",\n  \"paymentMethodId\": \"card-001\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api", "reservations"] }
          }
        },
        {
          "name": "Create reservation with rejected payment (demo PENDING_PAYMENT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"spaceId\": 1,\n  \"startDateTime\": \"2026-07-12T09:00:00\",\n  \"endDateTime\": \"2026-07-12T11:00:00\",\n  \"paymentMethodId\": \"card-reject\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api", "reservations"] }
          }
        },
        {
          "name": "Create overlapping reservation (demo 409)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"spaceId\": 1,\n  \"startDateTime\": \"2026-07-10T11:00:00\",\n  \"endDateTime\": \"2026-07-10T13:00:00\",\n  \"paymentMethodId\": \"card-002\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api", "reservations"] }
          }
        },
        {
          "name": "My reservations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/reservations/my", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "my"] }
          }
        },
        {
          "name": "Get reservation by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/reservations/1", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "1"] }
          }
        },
        {
          "name": "Reschedule reservation (owner or ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"startDateTime\": \"2026-07-10T15:00:00\",\n  \"endDateTime\": \"2026-07-10T17:00:00\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations/1/reschedule", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "1", "reschedule"] }
          }
        },
        {
          "name": "Cancel reservation",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/reservations/1/cancel", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "1", "cancel"] }
          }
        },
        {
          "name": "List all reservations (ADMIN)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/reservations", "host": ["{{baseUrl}}"], "path": ["api", "reservations"] }
          }
        },
        {
          "name": "Update reservation status (ADMIN)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CONFIRMED\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/reservations/1/status", "host": ["{{baseUrl}}"], "path": ["api", "reservations", "1", "status"] }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "List all reservations",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/reservations", "host": ["{{baseUrl}}"], "path": ["api", "admin", "reservations"] }
