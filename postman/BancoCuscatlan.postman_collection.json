        },
        {
          "name": "Cancel any reservation",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/reservations/1/cancel", "host": ["{{baseUrl}}"], "path": ["api", "admin", "reservations", "1", "cancel"] }
          }
        },
        {
          "name": "Update reservation status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/admin/reservations/1/status?status=CONFIRMED",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admin", "reservations", "1", "status"],
              "query": [{ "key": "status", "value": "CONFIRMED" }]
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
