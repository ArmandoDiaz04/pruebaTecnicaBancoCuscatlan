{
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "JWT signing secret."
    },
    {
      "name": "app.jwt.expiration",
      "type": "java.lang.Long",
      "description": "JWT expiration in milliseconds."
    },
    {
